APP_NAME=PaperMate API
APP_ENV=production
DEBUG=false
ENABLE_API_DOCS=false
LOG_LEVEL=INFO

MONGO_URL=mongodb://mongo:27017
MONGO_DB_NAME=papermate
MONGO_TIMEOUT_MS=2000

JWT_SECRET_KEY=change-this-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM API key. PaperMate currently uses OpenAI only.
# Copy this file to backend/.env and put your real key there.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional image understanding. If absent, PaperMate falls back to local OCR.
ANTHROPIC_API_KEY=
ANTHROPIC_VISION_MODEL=claude-3-5-sonnet-20241022
LOCAL_VLM_ENABLED=false

# Google login, not Gemini/LLM.
# Use the same OAuth Client ID as VITE_GOOGLE_CLIENT_ID in Vercel.
GOOGLE_CLIENT_ID=

# Semantic grounding is part of the default analysis engine.
ENABLE_BERT_GROUNDING=true
BERT_GROUNDING_MODEL=jhgan/ko-sroberta-multitask
# BGE-M3 provides stronger multilingual dense embeddings, but can be slow on CPU during first load.
# Sparse/ColBERT scoring requires a future FlagEmbedding reranker path.
# For a larger multilingual model on a GPU machine, you can also try Qwen/Qwen3-Embedding-8B.
# BERT_GROUNDING_MODEL=BAAI/bge-m3
# BERT_GROUNDING_MODEL=Qwen/Qwen3-Embedding-8B
BERT_GROUNDING_THRESHOLD=0.62
BERT_GROUNDING_INSTRUCTION=Given an answer sentence, retrieve the most relevant source passage from the uploaded document.

# English-heavy analysis paragraphs are translated to Korean with Argos Translate when available.
ENABLE_LOCAL_TRANSLATION=true
LOCAL_TRANSLATION_AUTO_INSTALL=true

# KoBERTopic-inspired topic extraction is part of the default analysis engine.
ENABLE_TOPIC_MODELING=true
TOPIC_MODEL_BACKEND=bertopic
TOPIC_MODEL_LIMIT=5

MAX_UPLOAD_MB=25
MAX_UPLOAD_FILES=10
HWPX_JAR=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-vercel-app.vercel.app
# Optional. Useful if you want Vercel preview deployment URLs to call the EC2 API.
# Keep this empty for the strictest production setting.
CORS_ORIGIN_REGEX=
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
