# Copy this file to .env before running docker compose on EC2.

# EC2 backend host port. Put nginx/HTTPS in front of this in production when possible.
BACKEND_PORT=8000

# Frontend values are configured in Vercel project settings.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-vercel-app.vercel.app
VITE_API_BASE_URL=https://api.example.com

