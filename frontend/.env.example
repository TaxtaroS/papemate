# Local frontend development.
# Copy to frontend/.env when running npm run dev from the frontend folder.
VITE_API_BASE_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Vercel production values are set in the Vercel dashboard:
# VITE_API_BASE_URL=https://api.example.com
# VITE_GOOGLE_CLIENT_ID=...
# VITE_GOOGLE_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app
